# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Database ---
# Local (docker-compose): matches docker-compose.yml defaults
DATABASE_URL=postgresql+psycopg2://postgres:localpass@localhost:5432/trucking_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localpass
POSTGRES_DB=trucking_agent

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
AGENT_MODEL=claude-haiku-4-5-20251001
REPORT_MODEL=claude-sonnet-5

# --- Samsara ---
SAMSARA_API_TOKEN=samsara_xxxxxxxxxxxxxxxx
SAMSARA_BASE_URL=https://api.samsara.com
# Set true only once the token has the "Media Retrieval" scope (dash cam video)
SAMSARA_FETCH_MEDIA=false

# --- Alvys TMS (planned; leave blank until you have credentials) ---
ALVYS_CLIENT_ID=
ALVYS_CLIENT_SECRET=

# --- Auth ---
# Long random string — signs login tokens. CHANGE THIS in production.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# --- App ---
# How often the background job pulls fresh data from Samsara (seconds)
SYNC_INTERVAL_SECONDS=60
# Admin phone for critical-fault SMS alerts (SMS not wired yet — see notifications.py)
ADMIN_PHONE=
# Read-only DB viewer tab. Exposes all tables — set false before hosting (no auth yet)
ADMIN_ENABLED=true
# Comma-separated list of allowed origins for the dashboard (CORS)
ALLOWED_ORIGINS=http://localhost:3000
